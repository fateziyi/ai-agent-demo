FROM python:3.12-slim-bookworm

WORKDIR /app

# 1. Install dependencies first (layer cached unless requirements.txt changes)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 2. Copy application source code
COPY app/ ./app/

# 3. Expose the FastAPI port
EXPOSE 8000

# 4. Run with uvicorn
# .env is NOT copied into image; secrets must be provided via runtime env vars
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]