# Dockerfile for Vue3 Frontend

# --- Stage 1: Build the Vue app ---
FROM node:20-alpine AS build-stage

WORKDIR /app

# Copy dependency manifests first (Docker layer caching)
COPY package*.json ./
RUN npm ci

# Copy source code and build
COPY . .
RUN npm run build

# --- Stage 2: Serve with Nginx ---
FROM nginx:alpine AS production-stage

# Copy custom Nginx config — uses env substitution for BACKEND_URL
COPY nginx.conf /etc/nginx/templates/default.conf.template

# Copy built static assets from build stage
COPY --from=build-stage /app/dist /usr/share/nginx/html

EXPOSE 80

# nginx:alpine supports envsubst via /etc/nginx/templates/
# Variables like ${BACKEND_URL} in nginx.conf are replaced at startup
# Default BACKEND_URL points to the backend container on Docker network
CMD ["sh", "-c", "envsubst '${BACKEND_URL}' < /etc/nginx/templates/default.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]